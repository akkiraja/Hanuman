{
  "cli": {
    "version": ">= 3.13.0"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_FIREBASE_SERVICE_ACCOUNT_BASE64": "$(EXPO_FIREBASE_SERVICE_ACCOUNT_BASE64)"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    }
  }
}


